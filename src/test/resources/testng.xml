<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="Sauce Demo ITM5"
       parallel="classes">
    <listeners>
        <listener class-name="utils.TestListener"></listener>
        <listener class-name="utils.AnnotationTransformer"/>
    </listeners>

    <test name="Thread 1">
        <classes>
            <class name="tests.LoginTest"/>
          </classes>
    </test>

    <test name="Thread 2">
        <classes>
            <class name="tests.LocatorTest"/>
            <class name="tests.CartTest"/>
        </classes>
    </test>
</suite>
